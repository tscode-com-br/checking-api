DATABASE_URL=sqlite:///./checking.db
FORMS_URL=https://forms.office.com/Pages/ResponsePage.aspx?id=QWJvW1ea5EuOUB36cueaV-4C0XpFTa1LmJM_FjZpp4pUOTFGR1QwSk00Vk5KQ0ExNUMzQldRSkpHWCQlQCN0PWcu&origin=QRCode
TZ_NAME=Asia/Singapore
DEVICE_SHARED_KEY=change-me
MOBILE_APP_SHARED_KEY=change-mobile-app-shared-key
PROVIDER_SHARED_KEY=PETROBRASP80P82P83
TRANSPORT_BOT_SHARED_KEY=change-transport-bot-shared-key
# Meta WhatsApp Cloud API:
# - WHATSAPP_WEBHOOK_VERIFY_TOKEN: valor secreto escolhido por voce e repetido no painel do webhook da Meta.
# - WHATSAPP_ACCESS_TOKEN: token permanente de System User.
# - WHATSAPP_PHONE_NUMBER_ID: App Dashboard > WhatsApp > API Setup > Phone number ID.
# - WHATSAPP_BUSINESS_ACCOUNT_ID: App Dashboard > WhatsApp > API Setup > WhatsApp Business Account ID.
# - WHATSAPP_APP_SECRET: App Dashboard > App Settings > Basic > App Secret.
# O telefone em si nao vai neste arquivo; ele precisa ser conectado ao WhatsApp Business para gerar o Phone number ID.
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-whatsapp-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=change-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v22.0
ADMIN_SESSION_SECRET=change-admin-session-secret
BOOTSTRAP_ADMIN_KEY=HR70
BOOTSTRAP_ADMIN_NAME=Tamer Salmem
BOOTSTRAP_ADMIN_PASSWORD=eAcacdLe2
WIFI_SSID=TS 14 PRO
WIFI_PASSWORD=00000000
HEARTBEAT_SECONDS=180
FORMS_TIMEOUT_SECONDS=30
FORMS_MAX_RETRIES=3
TRANSPORT_AI_ENABLED=false
TRANSPORT_AI_AGENT_MODE=agent
# Keep blank until this environment has dedicated load validation and explicit
# operational approval for Transport AI route calculations.
TRANSPORT_AI_OPERATIONAL_APPROVAL_EVIDENCE=
# Keep at 1 unless a dedicated load test approves a higher ceiling.
TRANSPORT_AI_MAX_CONCURRENT_RUNS=1
# Required to open/save Transport AI settings. Generate once and keep stable:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRANSPORT_AI_SETTINGS_ENCRYPTION_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-2025-08-07
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
TRANSPORT_AI_ROUTE_PROVIDER=here
TRANSPORT_AI_FAKE_MATRIX_ASYMMETRIC=false
TRANSPORT_AI_MAX_PASSENGERS_PER_RUN=80
TRANSPORT_AI_MAX_RUNTIME_SECONDS=180
TRANSPORT_AI_ROUTE_CACHE_TTL_SECONDS=3600
TRANSPORT_AI_GEOCODE_CACHE_TTL_DAYS=30

# DigitalOcean Spaces / S3-compatible object storage
# Required for Accident Mode archive ZIPs and video uploads.
# Leave blank to use local-disk fallback (development only).
DO_SPACES_ENDPOINT_URL=https://sfo3.digitaloceanspaces.com
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=change-me-bucket-name
DO_SPACES_ACCESS_KEY=change-me-access-key
DO_SPACES_SECRET_KEY=change-me-secret-key
# CDN URL served to clients for public/pre-signed object links:
DO_SPACES_PUBLIC_BASE_URL=https://change-me-bucket-name.sfo3.digitaloceanspaces.com

# SMTP e-mail delivery (Accident Mode: notificações de "help")
# Leave SMTP_HOST blank to disable e-mail (alerts will be silently skipped).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM_EMAIL=alerts@example.com
SMTP_FROM_NAME=CheckCheck
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
SMTP_TIMEOUT_SECONDS=30
SMTP_MAX_RETRIES=3
# Endereço que recebe cópia de todos os alertas de acidente (status=help):
SMTP_ACCIDENT_NOTIFY_EMAIL=safety-team@example.com
